# Скопируйте в .env и заполните своими значениями

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_API_URL=https://your-worker.workers.dev
# TELEGRAM_DIRECT_FILES=true  # только с VPN на ПК
OPENAI_API_KEY=your_proxyapi_key
USE_PROXYAPI=true
# IMAGE_GEN_MODEL=gpt-image-1
BOT_MODE=text
DEFAULT_VOICE=alloy
LOG_LEVEL=INFO
